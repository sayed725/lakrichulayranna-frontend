# ══════════════════════════════════════════
# লাকড়ি চুলায় রান্না — Backend Environment
# ══════════════════════════════════════════
# Copy this file to .env in your backend project and fill in your values.
# DO NOT commit .env to version control.

# ─── Server ───────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────
# PostgreSQL connection string (used by Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/lakrichulayranna_db

# ─── JWT ──────────────────────────────────
# Access token secret (shared with frontend JWT_SECRET)
JWT_SECRET=your_strong_jwt_secret_here
JWT_EXPIRES_IN=15m

# Refresh token secret
JWT_REFRESH_SECRET=your_strong_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# ─── File Uploads (Cloudinary) ────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (Optional) ─────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# EMAIL_FROM=noreply@lakrichulayranna.com

# ─── Payment (Optional) ───────────────────
# SSLCOMMERZ_STORE_ID=your_store_id
# SSLCOMMERZ_STORE_PASS=your_store_pass
# SSLCOMMERZ_IS_LIVE=false
